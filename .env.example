# MagicPlay Environment Configuration
# Copy this file to .env and fill in your API keys

# =============================================================================
# Required API Keys
# =============================================================================

# DeepSeek API key (for script generation)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DashScope API key (for image/video generation with wan2.6)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# =============================================================================
# Optional: Jimeng (即梦) API (alternative video generation)
# =============================================================================

# Jimeng AI credentials (https://www.volcengine.com)
# Requires Access Key + Secret Key for Volcengine authentication
JIMENG_ACCESS_KEY=your_access_key_here
JIMENG_SECRET_KEY=your_secret_key_here

# Jimeng API base URL (defaults to visual.volcengineapi.com)
# JIMENG_API_BASE_URL=https://visual.volcengineapi.com

# Default Jimeng aspect ratio (16:9, 4:3, 1:1, 3:4, 9:16, 21:9)
# JIMENG_DEFAULT_ASPECT_RATIO=16:9

# =============================================================================
# Optional Configuration
# =============================================================================

# Video generation settings
DEFAULT_VIDEO_DURATION=8
MIN_VIDEO_DURATION=2
MAX_VIDEO_DURATION=15

# Quality settings
DEFAULT_QUALITY_THRESHOLD=60.0
ENABLE_QUALITY_CHECK=true

# Caching
ENABLE_CACHING=true
CACHE_MAX_AGE_DAYS=30

# Parallel processing
MAX_PARALLEL_TASKS=3

# Logging
LOG_LEVEL=INFO

# Project environment
# MAGICPLAY_ENV=development
