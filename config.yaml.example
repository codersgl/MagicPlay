# =============================================================================
# MagicPlay 配置文件
# =============================================================================
# 复制此文件为 config.yaml 并填入你的配置
# 注意：config.yaml 会被 git 跟踪，请勿填写敏感信息（如 API keys）

# =============================================================================
# API 配置
# =============================================================================

# DeepSeek API (用于脚本生成)
deepseek_api_key: ""
deepseek_base_url: "https://api.deepseek.com"
deepseek_model: "deepseek-chat"

# DashScope API (用于图像/视频生成)
dashscope_api_key: ""
dashscope_base_url: ""

# 即梦 (Jimeng) API - 视频生成替代方案
jimeng_access_key: ""
jimeng_secret_key: ""
jimeng_api_base_url: "https://visual.volcengineapi.com"
jimeng_default_aspect_ratio: "16:9"

# =============================================================================
# 默认 Provider 设置
# =============================================================================

# 视频生成 provider: "qwen" (DashScope) 或 "jimeng" (即梦)
default_video_provider: "jimeng"

# 图像生成 provider (目前仅支持 qwen)
default_image_provider: "jimeng"

# =============================================================================
# 生成参数
# =============================================================================

# 视频时长 (秒)
default_video_duration: 8
min_video_duration: 2
max_video_duration: 15

# LLM 温度参数
default_temperature: 0.7

# 最大重试次数
max_retry_attempts: 3

# =============================================================================
# 质量设置
# =============================================================================

# 质量阈值
default_quality_threshold: 60.0

# 启用质量检查
enable_quality_check: true

# =============================================================================
# 缓存设置
# =============================================================================

# 启用缓存
enable_caching: true

# 缓存过期天数
cache_max_age_days: 30

# =============================================================================
# 并行处理
# =============================================================================

# 最大并行任务数
max_parallel_tasks: 3

# =============================================================================
# 日志设置
# =============================================================================

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
log_level: "INFO"

# 日志文件路径 (留空则仅输出到控制台)
log_file: ""

# =============================================================================
# 实验性功能
# =============================================================================

# 启用实验追踪
enable_experiments: false
